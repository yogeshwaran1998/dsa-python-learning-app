rules_version = '2';

// Firestore security rules for the DSA Learning App.
// Progress is stored per user at userProgress/{uid}. A signed-in user may only
// read and write their own document — never anyone else's.
service cloud.firestore {
  match /databases/{database}/documents {
    match /userProgress/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
